<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="clr-namespace:rightBright.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="rightBright.Views.CurveEditorView"
             x:DataType="vm:CurveEditorViewModel">
    <Design.DataContext>
        <vm:CurveEditorViewModel />
    </Design.DataContext>


    <Grid ColumnDefinitions="*, 170" RowDefinitions="Auto, *">
        <Label Grid.Row="0" Grid.Column="0"
               Content="{Binding SelectedScreen.ModelName, FallbackValue=''}"
               FontSize="18" Margin="10,10,0,0" />
        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,5,0"
                    Orientation="Horizontal" FlowDirection="RightToLeft">
            <Button Command="{Binding RequestCloseCommand}"
                    Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Label Classes="icon" FontWeight="Bold">&#xE4F6;</Label>
                </StackPanel>
            </Button>
        </StackPanel>

        <lvc:CartesianChart Grid.Row="1" Grid.Column="0" Series="{Binding Series}"
                            EasingFunction="{x:Null}"
                            Background="#EFF0F1" />

        <Border Grid.Row="1" Grid.Column="1"
                Padding="7,0">
            <StackPanel>
                <CheckBox Grid.Row="2" Grid.Column="0"
                          Margin="0,0,0,7"
                          IsChecked="{Binding Active}">
                    Aktiv
                </CheckBox>
                <Label Content="Minimum Helligkeit" />
                <TextBox Margin="0,0,0,7"
                         Text="{Binding MinBrightness}">
                </TextBox>
                <Label Content="Abflachung" />
                <TextBox Margin="0,0,0,7"
                         Text="{Binding Curve}">
                </TextBox>
                <Label Content="Progression" />
                <TextBox Margin="0,0,0,7"
                         Text="{Binding Progression}">
                </TextBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Command="{Binding ApplyCurveCommand}">
                        Übernehmen
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
