<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="clr-namespace:rightBright.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="rightBright.Views.CurveEditorView"
             x:DataType="vm:CurveEditorViewModel">
    <Design.DataContext>
        <vm:CurveEditorViewModel />
    </Design.DataContext>

    <DockPanel>
        <Label DockPanel.Dock="Top" Content="{Binding SelectedMonitor.ModelName}" FontSize="18" Margin="10,10,0,0"></Label>
        <lvc:CartesianChart>
            <lvc:CartesianChart.Series>
                <lvc:XamlLineSeries
                    Values="{Binding CurrentCurve}"

                    LineSmoothness="0"
                    Fill="#6BE0E0E0"
                    GeometrySize="0">
                    <lvc:XamlLineSeries.Stroke>
                        <lvc:SolidColorPaint Color="#A3A3A3" StrokeWidth="2" />
                    </lvc:XamlLineSeries.Stroke>
                </lvc:XamlLineSeries>
                <lvc:XamlLineSeries
                    Values="{Binding NewCurve}"
                    LineSmoothness="1"
                    Fill="#6bBFC9FF"
                    GeometrySize="0">
                    <lvc:XamlLineSeries.Stroke>
                        <lvc:SolidColorPaint Color="#415BFF" StrokeWidth="2" />
                    </lvc:XamlLineSeries.Stroke>
                </lvc:XamlLineSeries>
            </lvc:CartesianChart.Series>
        </lvc:CartesianChart>
    </DockPanel>
</UserControl>
