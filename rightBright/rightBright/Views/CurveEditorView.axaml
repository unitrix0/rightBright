<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:rightBright.Views.Controls"
             xmlns:localization="clr-namespace:rightBright.Localization"
             xmlns:vm="clr-namespace:rightBright.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="rightBright.Views.CurveEditorView"
             x:DataType="vm:CurveEditorViewModel">
    <Design.DataContext>
        <vm:CurveEditorViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="*, 190" RowDefinitions="Auto, *">
        <Label Grid.Row="0" Grid.Column="0"
               Content="{Binding SelectedScreen.ModelName, FallbackValue=''}"
               FontSize="18" Margin="10,10,0,0" />
        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,5,0"
                    Orientation="Horizontal" FlowDirection="RightToLeft">
            <Button Command="{Binding RequestCloseCommand}"
                    Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Label Classes="icon" FontWeight="Bold">&#xE4F6;</Label>
                </StackPanel>
            </Button>
        </StackPanel>

        <controls:BezierCurveEditorControl Grid.Row="1" Grid.Column="0"
                                           Margin="5,5,0,5"
                                           MinBrightness="{Binding MinBrightness}"
                                           ControlPointX="{Binding ControlPointX}"
                                           ControlPointY="{Binding ControlPointY}"
                                           MaxLux="{Binding MaxLux}"
                                           SavedMinBrightness="{Binding SavedMinBrightness}"
                                           SavedControlPointX="{Binding SavedControlPointX}"
                                           SavedControlPointY="{Binding SavedControlPointY}"
                                           SavedMaxLux="{Binding SavedMaxLux}"
                                           ShowSavedCurve="{Binding ShowSavedCurve}"
                                           CurrentLux="{Binding CurrentLux}" />

        <Border Grid.Row="1" Grid.Column="1"
                BorderBrush="LightGray"
                BorderThickness="1,0,0,0"
                Margin="0,0,0,10"
                Padding="12,0,5,0">
            <StackPanel>
                
                <CheckBox Margin="0,0,0,7"
                          IsChecked="{Binding Active}"
                          Content="{x:Static localization:Texts.CurveActive}" />

                <TextBlock Text="{x:Static localization:Texts.CurveMinBrightnessP0}"
                           Margin="0,5,0,3"
                           FontSize="12" />
                <NumericUpDown Value="{Binding MinBrightness}"
                               Minimum="0"
                               Maximum="99"
                               Increment="1"
                               FormatString="0"
                               Width="120"
                               HorizontalAlignment="Left" />

                <TextBlock Text="{x:Static localization:Texts.CurveHundredPercentAtLuxP2}"
                           Margin="0,10,0,3"
                           FontSize="12" />
                <NumericUpDown Value="{Binding MaxLux}"
                               Minimum="100"
                               Maximum="5000"
                               Increment="50"
                               FormatString="0"
                               Width="120"
                               HorizontalAlignment="Left" />

                <SplitButton HorizontalAlignment="Right"
                             Margin="0,10,0,0"
                             Content="{x:Static localization:Texts.CurveApply}"
                             Command="{Binding ApplyCurveCommand}">
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="{x:Static localization:Texts.CurveApplyToActive}"
                                      Command="{Binding ApplyCurveToAllActiveScreensCommand}" />
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
