<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:rightBright.ViewModels"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="450"
             x:Class="rightBright.Views.MainViewSideBar"
             x:DataType="viewModels:MainWindowViewModel">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <StackPanel>
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <Label FontSize="18"> Bildschirme</Label>
            <Button Grid.Column="1"
                    Command="{Binding DetectMonitorsCommand}"
                    Background="Transparent"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Monitore erkennen"
                    IsVisible="{Binding IsNotLoadingDisplays}">
                <Label Classes="icon">&#xE096;</Label>
            </Button>
        </Grid>
        <Label IsVisible="{Binding ApplicationViewModel.IsLoadingDisplays, TargetNullValue=false, FallbackValue=false}"
               FontSize="14"
               Margin="7"
               Padding="10"
               HorizontalAlignment="Center">
            Suche nach Monitoren...
        </Label>
        <ListBox ItemsSource="{Binding Displays}"
                 SelectedItem="{Binding SelectedScreenItem}"
                 IsVisible="{Binding IsNotLoadingDisplays}">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Margin" Value="0,5"></Setter>
                    <Setter Property="Padding" Value="0"></Setter>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="Border.screenCard">
                    <Setter Property="Background" Value="#6e44ff" />
                </Style>
                <Style Selector="ListBoxItem:selected Border.screenCard">
                    <Setter Property="Background" Value="#4F1FFF" />
                </Style>
                <Style Selector="ListBoxItem:pointerover Border.screenCard">
                    <Setter Property="Background" Value="#5F33FF" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Classes="screenCard" Margin="0" CornerRadius="5" Padding="3">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,*" Margin="0,0,5,0">
                            <Label Grid.Column="0" Grid.Row="0" FontSize="35" Margin="4,0"
                                   Foreground="White"
                                   Grid.RowSpan="2" Classes="icon">
                                &#xE32E;
                            </Label>

                            <Label Grid.Column="1" Grid.Row="0" Foreground="White" Content="{Binding ModelName}"
                                   FontWeight="Bold">
                            </Label>
                            <Grid Grid.Column="1" Grid.Row="1" ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" 
                                            VerticalAlignment="Center" 
                                            Margin="0,0,7,0">
                                    <Label Classes="icon" Foreground="White">&#xE472;</Label>
                                    <Label Grid.Column="1" HorizontalAlignment="Right" Foreground="White" Padding="0,2,0,0"
                                           Content="{Binding LastBrightnessSet, StringFormat='{}{0}%'}"
                                           FontSize="13" />    
                                </StackPanel>
                                <Label Grid.Column="1" Foreground="White" Content="{Binding DeviceName}"
                                       FontSize="13" />
                            </Grid>
                            
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Border BorderBrush="#909090" BorderThickness="0,1,0,0" Margin="0,10,0,10" />
        <Border Background="#00524b" Margin="0" CornerRadius="5" Padding="3">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,*" Margin="0,4">
                <Label Grid.RowSpan="2"
                       Classes="icon" FontSize="35" Foreground="White"
                       Margin="4,0">
                    &#xE610;
                </Label>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4"
                            ToolTip.Tip="{Binding SelectedSensor.FriendlyName, TargetNullValue='', FallbackValue=''}">
                    <TextBlock FontWeight="Bold" Foreground="White">Sensor:</TextBlock>
                    <TextBlock Text="{Binding SelectedSensor.FriendlyName, TargetNullValue='', FallbackValue=''}"
                               Width="185" Foreground="White" />

                </StackPanel>

                <Grid Grid.Column="1" Grid.Row="1" RowDefinitions="*" ColumnDefinitions="Auto,*,Auto,*,Auto,*">
                    <TextBlock Grid.Column="0" Foreground="White">min:</TextBlock>
                    <TextBlock Grid.Column="1" Foreground="White" Margin="4,0,4,0"
                               Text="{Binding SelectedSensor.MinValue, TargetNullValue=0, FallbackValue=0}" />
                    <TextBlock Grid.Column="2" Foreground="White">current:</TextBlock>
                    <TextBlock Grid.Column="3" Foreground="White" Margin="4,0,4,0"
                               Text="{Binding SelectedSensor.CurrentValue, TargetNullValue=0, FallbackValue=0}" />
                    <TextBlock Grid.Column="4" Foreground="White">max:</TextBlock>
                    <TextBlock Grid.Column="5" Foreground="White" Margin="4,0,0,0"
                               Text="{Binding SelectedSensor.MaxValue, TargetNullValue=0, FallbackValue=0}" />
                </Grid>
            </Grid>
        </Border>

    </StackPanel>
</UserControl>
