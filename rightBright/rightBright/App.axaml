<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="rightBright.App"
             xmlns:local="using:rightBright"
             xmlns:views="clr-namespace:rightBright.Views"
             xmlns:viewModels="clr-namespace:rightBright.ViewModels"
             RequestedThemeVariant="Default"
             x:DataType="viewModels:ApplicationViewModel"
             x:CompileBindings="True">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>
    
    <!-- <Application.DataContext> -->
    <!--     <views:ApplicationViewModel /> -->
    <!-- </Application.DataContext> -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="Styles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <FontFamily x:Key="PhosphorThin">/Assets/Fonts/Phosphor-Thin.ttf#Phosphor-Thin</FontFamily>
        <FontFamily x:Key="PhosphorRegular">/Assets/Fonts/Phosphor.ttf#Phosphor</FontFamily>
        <SolidColorBrush x:Key="PrimaryBackground">#EFF0F1</SolidColorBrush>
        <SolidColorBrush x:Key="CustomWhite">#ECE5F0</SolidColorBrush>
    </Application.Resources>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="{Binding AppIcon}">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Öffnen" Command="{Binding OpenMainWindowCommand}" />
                        <NativeMenuItem Header="Pause" ToggleType="CheckBox"
                                        Command="{Binding ToggleSuspendUpdatingCommand}"
                                        IsChecked="{Binding Suspend, Mode=TwoWay}"/>
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" Command="{Binding EndProgramCommand}" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
